		"@types/node": "^26.1.1",
		"autoprefixer": "^10.5.4",
		"bits-ui": "^2.18.1",
		"clsx": "^2.1.1",
		"drizzle-kit": "^0.31.10",
		"eslint": "^10.7.0",
